generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id             String              @id @default(cuid())
  name           String
  date           DateTime
  status         String              @default("DRAFT")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  mappings       SectionMapping[]
  transcriptions TranscriptionData[]
  speakers       SessionSpeaker[]
  actionHistory  ActionHistory[]     // Undo/Redo履歴
}

// 話者マスターテーブル
model Speaker {
  id           String   @id @default(cuid())
  fullName     String   // 正式名称（例：比嘉武宏）
  displayName  String   // 表示名（例：比嘉武宏議員）
  aliases      String   // カンマ区切りの別名（例：比嘉,ヒガ,比嘉議員）
  speakerType  String   @default("MEMBER") // MEMBER（議員）, STAFF（職員）, OTHER（その他）
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  sessionSpeakers SessionSpeaker[]
}

// セッションと話者の関連テーブル
model SessionSpeaker {
  id         String   @id @default(cuid())
  sessionId  String
  speakerId  String
  orderIndex Int      // 発言順序
  
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speaker    Speaker  @relation(fields: [speakerId], references: [id])
  
  @@unique([sessionId, speakerId])
}

model TranscriptionData {
  id               String    @id @default(cuid())
  sessionId        String
  source           String
  originalFileName String
  uploadedAt       DateTime  @default(now())
  processedAt      DateTime?
  status           String    @default("UPLOADED")
  fileType         String    @default("text") // "text" or "audio"
  fileSize         Int?      // File size in bytes
  duration         Float?    // Audio duration in seconds (for audio files)
  audioFormat      String?   // Audio format (mp3, wav, etc.)
  transcriptionId  String?   // Whisper API transcription ID
  sections         Section[]
  session          Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Section {
  id                  String            @id @default(cuid())
  transcriptionDataId String
  sectionNumber       String
  speaker             String
  speakerId           String?           // 話者マスターへの参照（NULL可）
  timestamp           String
  endTimestamp        String?
  content             String
  order               Int
  isExcluded          Boolean           @default(false)
  transcriptionData   TranscriptionData @relation(fields: [transcriptionDataId], references: [id], onDelete: Cascade)
  manusMappings       SectionMapping[]  @relation("ManusSection")
  nottaMappings       SectionMapping[]  @relation("NottaSection")
  highlights          Highlight[]       // ハイライト機能

  @@index([transcriptionDataId])
}

model Highlight {
  id          String   @id @default(cuid())
  sectionId   String
  startOffset Int      // テキスト内の開始位置
  endOffset   Int      // テキスト内の終了位置
  color       String   // ハイライト色 (yellow, blue, green, pink, orange)
  text        String   // ハイライトされたテキスト（検証用）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  section     Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

model SectionMapping {
  id               String   @id @default(cuid())
  sessionId        String
  nottaSectionId   String
  manusSectionId   String
  confidence       Float
  isManuallyMapped Boolean  @default(false)
  createdAt        DateTime @default(now())
  manusSection     Section  @relation("ManusSection", fields: [manusSectionId], references: [id])
  nottaSection     Section  @relation("NottaSection", fields: [nottaSectionId], references: [id])
  session          Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([nottaSectionId, manusSectionId])
  @@index([sessionId])
}

// Undo/Redo機能のための操作履歴
model ActionHistory {
  id          String     @id @default(cuid())
  sessionId   String
  actionType  ActionType // 操作タイプ
  targetId    String     // 操作対象のID（ハイライトID、マッピングIDなど）
  beforeState Json?      // 操作前の状態（JSON形式）
  afterState  Json?      // 操作後の状態（JSON形式）
  createdAt   DateTime   @default(now())
  session     Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// 操作タイプの列挙型
enum ActionType {
  HIGHLIGHT_ADD      // ハイライト追加
  HIGHLIGHT_DELETE   // ハイライト削除
  HIGHLIGHT_UPDATE   // ハイライト更新
  MAPPING_CREATE     // マッピング作成
  MAPPING_UPDATE     // マッピング更新
  MAPPING_DELETE     // マッピング削除
  SECTION_EXCLUDE    // セクション除外
  SECTION_INCLUDE    // セクション除外解除
}
