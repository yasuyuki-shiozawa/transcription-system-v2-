{
  "name": "transcription-system",
  "version": "1.0.0",
  "description": "議会議事録作成システム - セクション番号付与ツール",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/section-numbering/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "process": "ts-node src/section-numbering/index.ts",
    "qa:websocket": "./scripts/run-websocket-qa.sh",
    "qa:websocket:install": "./scripts/run-websocket-qa.sh --install",
    "qa:frontend": "./scripts/run-websocket-qa.sh --frontend",
    "qa:backend": "./scripts/run-websocket-qa.sh --backend",
    "qa:performance": "./scripts/run-websocket-qa.sh --performance",
    "qa:metrics": "./scripts/run-websocket-qa.sh --metrics",
    "test:all": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && npm test",
    "test:websocket": "cd backend && npm run test:websocket && cd ../frontend && npm test -- --testPathPattern=\"WebSocket\"",
    "dev:full": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build:all": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "start:full": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:frontend": "cd frontend && npm start",
    "start:backend": "cd backend && npm start",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "coverage:combined": "npm run coverage:frontend && npm run coverage:backend",
    "coverage:frontend": "cd frontend && npm run test:coverage",
    "coverage:backend": "cd backend && npm run test:coverage"
  },
  "keywords": ["transcription", "notta", "section-numbering"],
  "author": "Flatto Legal Office",
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3",
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "commander": "^12.0.0"
  }
}