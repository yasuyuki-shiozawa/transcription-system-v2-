# ローカルサーバー用環境変数設定

# バックエンド設定
NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://postgres:password@postgres:5432/transcription_db

# セキュリティ設定
JWT_SECRET=your-local-test-secret-key-change-this
JWT_EXPIRES_IN=8h

# ファイルアップロード設定
MAX_FILE_SIZE=52428800
UPLOAD_DIR=/app/uploads

# VPN最適化設定
VPN_OPTIMIZATION=true
REQUEST_TIMEOUT=120000

# アクセス制限（社内ネットワークのみ）
ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.100:3000

# ログ設定
LOG_LEVEL=info